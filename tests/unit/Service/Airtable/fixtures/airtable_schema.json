{
  "tableSchemas": [
    {
      "id": "tblPROJECTS",
      "name": "Projects",
      "columns": [
        {
          "id": "fldNAME",
          "name": "Name",
          "type": "text"
        },
        {
          "id": "fldNOTES",
          "name": "Notes",
          "type": "richText"
        },
        {
          "id": "fldURL",
          "name": "Website",
          "type": "url"
        },
        {
          "id": "fldEMAIL",
          "name": "Contact email",
          "type": "email"
        },
        {
          "id": "fldPHONE",
          "name": "Phone",
          "type": "phone"
        },
        {
          "id": "fldBUDGET",
          "name": "Budget",
          "type": "number",
          "typeOptions": {
            "precision": 2
          }
        },
        {
          "id": "fldAMOUNT",
          "name": "Amount",
          "type": "currency",
          "typeOptions": {
            "symbol": "$",
            "precision": 2
          }
        },
        {
          "id": "fldPCT",
          "name": "Completion",
          "type": "percent",
          "typeOptions": {
            "precision": 0
          }
        },
        {
          "id": "fldPRIO",
          "name": "Priority",
          "type": "rating",
          "typeOptions": {
            "max": 5
          }
        },
        {
          "id": "fldDUR",
          "name": "Time spent",
          "type": "duration"
        },
        {
          "id": "fldCOMPLETE",
          "name": "Complete",
          "type": "checkbox"
        },
        {
          "id": "fldDUE",
          "name": "Due date",
          "type": "date"
        },
        {
          "id": "fldUPDATED",
          "name": "Last updated",
          "type": "dateTime"
        },
        {
          "id": "fldCREATED",
          "name": "Created",
          "type": "createdTime"
        },
        {
          "id": "fldMODIFIED",
          "name": "Modified",
          "type": "lastModifiedTime"
        },
        {
          "id": "fldSTATUS",
          "name": "Status",
          "type": "singleSelect",
          "typeOptions": {
            "choices": [
              {"id": "selTODO",       "name": "Todo"},
              {"id": "selINPROG",     "name": "In Progress"},
              {"id": "selDONE",       "name": "Done"}
            ]
          }
        },
        {
          "id": "fldTAGS",
          "name": "Tags",
          "type": "multiSelect",
          "typeOptions": {
            "choices": [
              {"id": "selDESIGN",  "name": "Design"},
              {"id": "selDEV",     "name": "Development"},
              {"id": "selQA",      "name": "QA"}
            ]
          }
        },
        {
          "id": "fldOWNER",
          "name": "Owner",
          "type": "singleCollaborator"
        },
        {
          "id": "fldTEAM",
          "name": "Team",
          "type": "multipleCollaborators"
        },
        {
          "id": "fldCREATEDBY",
          "name": "Created by",
          "type": "createdBy"
        },
        {
          "id": "fldMODIFIEDBY",
          "name": "Modified by",
          "type": "lastModifiedBy"
        },
        {
          "id": "fldBARCODE",
          "name": "Barcode",
          "type": "barcode"
        },
        {
          "id": "fldROWID",
          "name": "Row #",
          "type": "autoNumber"
        },
        {
          "id": "fldFORMULA",
          "name": "Auto total",
          "type": "formula",
          "typeOptions": {
            "formula": "{Budget} + {Amount}"
          }
        },
        {
          "id": "fldLINKED",
          "name": "Related tasks",
          "type": "foreignKey"
        },
        {
          "id": "fldLOOKUP",
          "name": "Task names",
          "type": "lookup"
        },
        {
          "id": "fldROLLUP",
          "name": "Total hours",
          "type": "rollup"
        },
        {
          "id": "fldCOUNT",
          "name": "Task count",
          "type": "count"
        },
        {
          "id": "fldBUTTON",
          "name": "Send report",
          "type": "button"
        },
        {
          "id": "fldATTACH",
          "name": "Files",
          "type": "multipleAttachments"
        },
        {
          "id": "fldAITEXT",
          "name": "AI summary",
          "type": "aiText"
        }
      ]
    }
  ],
